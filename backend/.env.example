# MongoDB Atlas connection
MONGO_URL=mongodb://localhost:27017
DB_NAME=vezubunye

# Auth
JWT_SECRET=change-me-long-random-string
TOKEN_HOURS=72

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,https://vezubunye.com,https://www.vezubunye.com

# Cloudinary for daily capture photos (optional; falls back to MongoDB storage)
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Seed passwords (used by seed.py)
WERNER_PASSWORD=
PIERRE_PASSWORD=
STEVEN_PASSWORD=
